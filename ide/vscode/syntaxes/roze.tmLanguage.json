{
  "name": "Roze",
  "scopeName": "source.roze",
  "fileTypes": ["roze"],
  "patterns": [
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.roze",
          "match": "\\b(if|else|for|while|return|match|break|continue|import)\\b"
        },
        {
          "name": "keyword.declaration.roze",
          "match": "\\b(let|mut|func|class|interface|extends|implements|new)\\b"
        },
        {
          "name": "keyword.other.roze",
          "match": "\\b(true|false|null|this|super|async|await|try|catch|throw)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.roze",
          "match": "\\b(int|float|string|bool|void|any|unknown|never)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.roze",
          "match": "\\bfunc\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": {
              "name": "entity.name.function.roze"
            }
          }
        },
        {
          "name": "support.function.builtin.roze",
          "match": "\\b(println|print|read_line|assert|panic)\\b"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.roze",
          "match": "//.*$"
        },
        {
          "name": "comment.block.roze",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.roze",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.roze",
              "match": "\\\\(n|t|r|\\\\|\"|')"
            }
          ]
        },
        {
          "name": "string.quoted.single.roze",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.roze",
              "match": "\\\\(n|t|r|\\\\|\"|')"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.roze",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.roze",
          "match": "(\\+\\+|--|\\+|-|\\*|/|%|==|!=|<|>|<=|>=|&&|\\|\\||!|\\?|:|=|\\+=|-=|\\*=|/=)"
        }
      ]
    }
  }
}